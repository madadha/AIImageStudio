<Window x:Class="SmartChat.WPF.Views.ChatWindowGemini"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gemini Chat"
        Height="700"
        Width="1000"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Gemini Chat"
                           Style="{StaticResource TitleTextStyle}"/>
                <TextBlock Text="SmartChat.WPF"
                           Style="{StaticResource SubtitleTextStyle}"/>
            </StackPanel>
        </Border>

        <!-- Chat Area -->
        <Border Grid.Row="1"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,0,0,15">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="txtChatHistory"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         BorderThickness="0"
                         Background="Transparent"
                         FontSize="15"/>
            </ScrollViewer>
        </Border>

        <!-- Message Input -->
        <Border Grid.Row="2"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Your Message"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>
                <TextBox x:Name="txtMessage"
                         Height="90"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Style="{StaticResource ValidatedTextBoxStyle}"
                         KeyDown="txtMessage_KeyDown"/>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <UniformGrid Grid.Row="3" Columns="4" Rows="1">
            <Button x:Name="btnSend"
                    Content="Send"
                    Height="55"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="btnSend_Click"/>

            <Button x:Name="btnClearChat"
                    Content="Clear Chat"
                    Height="55"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="btnClearChat_Click"/>

            <Button x:Name="btnClearMemory"
                    Content="Clear Memory"
                    Height="55"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="btnClearMemory_Click"/>

            <Button x:Name="btnBack"
                    Content="Back"
                    Height="55"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="btnBack_Click"/>
        </UniformGrid>
    </Grid>
</Window>